################################################################################
# .env BEISPIEL-DATEI
# 
# ANLEITUNG:
# 1. Kopiere diese Datei → umbenennen zu .env (ohne .example)
# 2. Fülle deine echten Tokens ein
# 3. SPEICHERN
# 4. Bot starten
# 
# ⚠️ WICHTIG: Die .env Datei NIEMALS öffentlich machen oder hochladen!
# Sie enthält geheime Tokens!
################################################################################

# ──────────────────────────────────────────────────────────────────────────────
# TELEGRAM TOKEN
# ──────────────────────────────────────────────────────────────────────────────
# So bekommst du den Token:
# 1. Öffne Telegram → Suche "@BotFather"
# 2. Schreibe: /start
# 3. Schreibe: /newbot
# 4. Folge den Anweisungen
# 5. Der Token sieht so aus: 123456789:XXXXXXXXXXXXXXXXXXX

TELEGRAM_TOKEN=123456789:XXXXXXXXXXXXXXXXXXX_HIER_EINFUEGEN

# ──────────────────────────────────────────────────────────────────────────────
# TELEGRAM CHAT ID
# ──────────────────────────────────────────────────────────────────────────────
# So bekommst du deine Chat ID:
# 1. Schreibe dem Bot den du gerade erstellt hast: /start
# 2. Öffne diesen Link in deinem Browser:
#    https://api.telegram.org/bot[HIER_DEIN_TOKEN]/getUpdates
# 3. Suche nach "chat":{"id": → Diese Zahl ist deine Chat ID

TELEGRAM_CHAT_ID=987654321_HIER_EINFUEGEN

# ──────────────────────────────────────────────────────────────────────────────
# DISCORD TOKEN
# ──────────────────────────────────────────────────────────────────────────────
# So bekommst du den Token:
# 1. Gehe zu https://discord.com/developers/applications
# 2. Klick "New Application"
# 3. Gib einen Namen ein (z.B. "Vinted Bot")
# 4. Gehe zu "Bot" → "Add Bot"
# 5. Unter "TOKEN" → "Copy"
# 6. Der Token sieht so aus: dzA1adfgd.XXXXXXXXXXXXXXXXXXXX

DISCORD_TOKEN=dzA1adfgd.XXXXXXXXXXXXXXXXXXXX_HIER_EINFUEGEN

# ──────────────────────────────────────────────────────────────────────────────
# DISCORD CHANNEL ID
# ──────────────────────────────────────────────────────────────────────────────
# So bekommst du die Channel ID:
# 1. Rechtsklick auf den Discord Channel (wo Bot posten soll)
# 2. "Copy Channel ID"
# 3. Die ID sieht so aus: 123456789012345678

DISCORD_CHANNEL_ID=123456789012345678_HIER_EINFUEGEN
