# ------------------------------------------------------------------------------
# VINTED SCRAPER - KONFIGURATIONSTEMPLATE (.env)
# ------------------------------------------------------------------------------
# ANLEITUNG: 
# 1. Diese Datei kopieren und in '.env' umbenennen.
# 2. Deine echten Daten unten eintragen.
# ------------------------------------------------------------------------------

# 🔑 DISCORD BOT SETTINGS
# Deinen Token findest du unter: https://discord.com/developers/applications
DISCORD_TOKEN=DEIN_DISCORD_BOT_TOKEN_HIER

# Die ID des Kanals, in dem der Bot die ersten Infos posten soll
DISCORD_CHANNEL_ID=DEINE_CHANNEL_ID_HIER

# ☁️ MONGODB ATLAS (Cloud Datenbank)
# Format: mongodb+srv://USER:PASSWORT@cluster.xxxx.mongodb.net/
# Wichtig für Persistence (Speichert gesehen Artikel & Suchen dauerhaft)
MONGODB_URI=DEIN_MONGODB_URI_HIER

# 🌐 PROXY (Optional)
# Falls du Proxies nutzt, hier eintragen oder im proxy_manager.py hinterlegen.
# Format: http://user:pass@host:port
PROXY_URL=
